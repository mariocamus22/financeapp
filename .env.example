# Copia a .env.local y rellena con valores del panel de Supabase (Settings → API).
# En Vercel: Project → Settings → Environment Variables (Production y Preview).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Clave pública del cliente: suele ser "anon" (JWT). Si usas la clave publishable nueva de Supabase,
# prueba también aquí; si el SDK falla, usa la anon legacy del dashboard.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
